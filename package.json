{
  "name": "hackycy-cli",
  "type": "module",
  "version": "0.0.0",
  "description": "hackycy的脚手架工具",
  "trustedDependencies": [
    "eslint",
    "simple-git-hooks",
    "lint-staged"
  ],
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/hackycy-collection/hackycy-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackycy-collection/hackycy-cli.git"
  },
  "bugs": "https://github.com/hackycy-collection/hackycy-cli/issues",
  "keywords": [
    "cli"
  ],
  "sideEffects": false,
  "module": "src/index.ts",
  "scripts": {
    "build": "bun build",
    "dev": "bun --watch src/index.ts",
    "lint": "eslint --cache .",
    "release": "bumpp",
    "test": "bun src/cli.ts",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@types/bun": "latest",
    "@types/node": "^24.10.0",
    "bumpp": "^10.3.1",
    "eslint": "^9.39.1",
    "lint-staged": "^16.2.6",
    "publint": "^0.3.17",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "npx eslint --fix"
  }
}
