{
  "name": "hackycy-cli",
  "type": "module",
  "version": "0.0.9",
  "description": "hackycy的脚手架工具",
  "trustedDependencies": [
    "eslint",
    "simple-git-hooks",
    "lint-staged"
  ],
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/hackycy-collection/hackycy-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackycy-collection/hackycy-cli.git"
  },
  "bugs": "https://github.com/hackycy-collection/hackycy-cli/issues",
  "keywords": [
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "lint": "eslint --cache .",
    "release": "bumpp",
    "test": "bun src/cli.ts",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "ansis": "^4.2.0",
    "cac": "^6.7.14",
    "dayjs": "^1.11.19",
    "fflate": "^0.8.2",
    "reveal-file": "^0.1.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@types/bun": "latest",
    "@types/node": "^24.11.0",
    "bumpp": "^10.4.1",
    "eslint": "^9.39.3",
    "lint-staged": "^16.3.1",
    "publint": "^0.3.17",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint"
  }
}
